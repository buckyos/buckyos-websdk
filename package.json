{
  "name": "buckyos",
  "version": "1.5.0",
  "description": "BuckyOS WebSDK for browser and Node.js environments",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "browser": "dist/browser.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "import": "./dist/browser.mjs",
        "require": "./dist/browser.cjs"
      },
      "node": {
        "import": "./dist/node.mjs",
        "require": "./dist/node.cjs"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.cjs",
      "default": "./dist/browser.mjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.cjs",
      "default": "./dist/node.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && vite build && tsc -p tsconfig.build.json",
    "types": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:all": "pnpm run build",
    "dev": "vite",
    "demo:app-client": "pnpm exec ts-node examples/app_client_demo.ts",
    "demo:app-service:debug": "pnpm exec ts-node examples/app_service_local_debug.ts",
    "debug:systest": "bash ./tests/scripts/debug_systest.sh",
    "test:app-service:debug": "bash ./tests/scripts/test_app_service_debug.sh",
    "test": "jest",
    "test:browser:real:prepare": "node tests/scripts/prepare_real_browser_test.mjs",
    "test:browser:real": "pnpm run build && pnpm run test:browser:real:prepare && npx playwright test tests/browser/real-browser/playwright.spec.js --reporter=line",
    "test:app-client": "jest --runInBand tests/app-client",
    "test:app-client:integration": "BUCKYOS_RUN_INTEGRATION_TESTS=1 jest --runInBand tests/app-client",
    "test:app-service": "jest --runInBand tests/app-service",
    "test:app-service:integration": "BUCKYOS_RUN_INTEGRATION_TESTS=1 jest --runInBand tests/app-service",
    "test:all": "bash ./run_all_test.sh",
    "prepublishOnly": "pnpm run build:all"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "vite": "^4.0.0"
  },
  "dependencies": {
    "jssha": "^3.3.1",
    "terser": "^5.36.0",
    "unixcrypt": "^2.0.0"
  }
}
